# ==========================================
# xiaozhi-server Git Attributes
# ==========================================

# ---------------
# 文本文件 - 自动换行符处理
# ---------------
*.txt         text=auto
*.py          text=auto
*.md          text=auto
*.yaml        text=auto
*.yml         text=auto
*.json        text=auto
*.html        text=auto
*.css         text=auto
*.js          text=auto
*.ts          text=auto
*.sh          text=auto eol=lf
*.bat         text=auto eol=crlf
*.ps1         text=auto eol=crlf

# ---------------
# 二进制文件 - 不进行换行符转换
# ---------------
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.bmp         binary
*.ico         binary
*.svg         text
*.webp        binary

# 音频文件
*.wav         binary
*.mp3         binary
*.opus        binary
*.p3          binary
*.flac        binary
*.aac         binary
*.ogg         binary

# 模型文件
*.pt          binary
*.pth         binary
*.onnx        binary
*.bin         binary
*.model       binary
*.pb          binary
*.h5          binary
*.hd5         binary
*.ckpt        binary
*.safetensors binary

# 压缩文件
*.zip         binary
*.tar         binary
*.gz          binary
*.bz2         binary
*.xz          binary
*.7z          binary
*.rar         binary

# 文档
*.pdf         binary
*.doc         binary
*.docx        binary
*.xls         binary
*.xlsx        binary
*.ppt         binary
*.pptx        binary

# 字体
*.ttf         binary
*.otf         binary
*.woff        binary
*.woff2       binary
*.eot         binary

# ---------------
# 大文件 - 使用 Git LFS 管理
# ---------------
# 如需使用 Git LFS，取消下面的注释并安装 git-lfs
#*.pt          filter=lfs diff=lfs merge=lfs -text
#*.pth         filter=lfs diff=lfs merge=lfs -text
#*.onnx        filter=lfs diff=lfs merge=lfs -text
#*.bin         filter=lfs diff=lfs merge=lfs -text
#*.mp3         filter=lfs diff=lfs merge=lfs -text
#*.wav         filter=lfs diff=lfs merge=lfs -text

# ---------------
# 差异显示优化
# ---------------
*.py          diff=python
*.md          diff=markdown
*.html        diff=html
*.css         diff=css
*.js          diff=javascript

# ---------------
# 导出忽略
# ---------------
.gitignore      export-ignore
.gitattributes  export-ignore
.github         export-ignore
